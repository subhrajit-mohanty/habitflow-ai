# HabitFlow AI — Environment Variables
# Copy to .env and fill in your values

# App
DEBUG=true
API_PREFIX=/v1

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# JWT (from Supabase dashboard → Settings → API → JWT Secret)
JWT_SECRET=your-jwt-secret
JWT_ALGORITHM=HS256

# AI / LLM
ANTHROPIC_API_KEY=sk-ant-...          # optional — only if you use Anthropic directly
OPENAI_API_KEY=sk-...                  # optional
GOOGLE_GEMINI_API_KEY=AIza...          # required — free AI for all users
AI_MODEL=claude-sonnet-4-20250514
AI_MAX_TOKENS=1024
FREE_AI_MODEL=gemini-2.0-flash
FREE_AI_PROVIDER=gemini

# OpenRouter (users add their own key via the app — no app-level key needed)
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_DEFAULT_MODEL=google/gemini-2.0-flash-exp:free

# Redis (optional, for caching)
REDIS_URL=redis://localhost:6379/0

# Firebase (push notifications)
FIREBASE_CREDENTIALS_PATH=./firebase-credentials.json

# Storage
STORAGE_BUCKET=habitflow-uploads
MAX_UPLOAD_SIZE_MB=10
